---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import Work from "../components/Work.astro";
import About from "../components/About.astro";
import Contact from "../components/Contact.astro";

const pageTitle = "Josh Winningham - Full Stack Developer & SEO Specialist";
const pageDescription =
	"Full Stack Developer & SEO Specialist building production-ready web applications with React, Next.js and .NET. Explore selected work and get in touch.";
const ogImage = "https://images.pexels.com/photos/546819/pexels-photo-546819.jpeg";
---

<Layout title={pageTitle} description={pageDescription} image={ogImage}>
	<Hero />
	<Work />
	<About />
	<Contact />
</Layout>
