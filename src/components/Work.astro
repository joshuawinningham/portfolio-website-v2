---
import FeaturedRow from "./FeaturedRow.astro";
import ProjectCard from "./ProjectCard.astro";
import Icon from "./Icon.astro";
import { projects, categories } from "../data/projects";

const realProjects = projects.filter((p) => !p.foundation);
const featuredProjects = realProjects.slice(0, 3);
const featuredSet = new Set(featuredProjects);
const foundationProjects = projects.filter((p) => p.foundation);

// A card belongs to the default "All" grid when it is neither a featured row
// nor a demoted Foundations entry.
const isDefault = (p: (typeof projects)[number]) =>
	!p.foundation && !featuredSet.has(p);
---

<section id="work" data-r="work" class="work">
	<div data-r="work-head" data-reveal class="work-head">
		<div>
			<p class="eyebrow">Selected work</p>
			<h2 class="work-title">Things I've built &amp; shipped</h2>
		</div>
		<span class="work-meta">11 projects · 2024–2026</span>
	</div>

	<!-- Featured alternating rows (visible in the default "All" view) -->
	<div id="featured-rows" class="featured-rows">
		{featuredProjects.map((p, i) => <FeaturedRow project={p} index={i} />)}
	</div>

	<!-- Grid heading -->
	<div id="grid-heading" class="grid-heading">
		<h3 id="grid-heading-text">More projects</h3>
		<span class="rule"></span>
	</div>

	<!-- Filter chips -->
	<div class="filters">
		{
			categories.map((label) => (
				<button
					type="button"
					class:list={["work-chip", { "chip-on": label === "All" }]}
					data-filter={label}
				>
					{label}
				</button>
			))
		}
	</div>

	<!-- Project grid (all cards rendered; JS toggles visibility) -->
	<div id="work-grid" data-r="grid" class="work-grid">
		{projects.map((p) => <ProjectCard project={p} inDefault={isDefault(p)} />)}
	</div>

	<!-- Foundations (visible in the default "All" view only) -->
	<div id="foundations" data-reveal class="foundations">
		<div class="grid-heading">
			<h3>Foundations</h3>
			<span class="rule"></span>
		</div>
		<p class="foundations-lede">
			Earlier builds and learning projects — where the fundamentals got their reps.
		</p>
		<div class="foundations-list">
			{
				foundationProjects.map((p) => (
					<div class="foundation-item">
						<div class="foundation-meta">
							<span class="foundation-title">{p.title}</span>
							<span class="foundation-tag">{p.tag}</span>
						</div>
						<div class="foundation-links">
							<a href={p.github} target="_blank" rel="noopener noreferrer" class="lnk-muted">
								<Icon name="github" size={14} aria-hidden="true" /> Code
							</a>
							<a href={p.live} target="_blank" rel="noopener noreferrer" class="lnk-accent">
								Live <span>→</span>
							</a>
						</div>
					</div>
				))
			}
		</div>
	</div>
</section>

<style>
	.work {
		scroll-margin-top: 80px;
		max-width: 1200px;
		margin: 0 auto;
		padding: 40px 32px 88px;
	}
	.work-head {
		display: flex;
		align-items: flex-end;
		justify-content: space-between;
		gap: 24px;
		flex-wrap: wrap;
		margin-bottom: 26px;
		padding-bottom: 22px;
		border-bottom: 1px solid var(--line);
	}
	.eyebrow {
		font-size: 12px;
		font-weight: 600;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--fg3);
		margin: 0 0 9px;
	}
	.work-title {
		font-family: "Newsreader", serif;
		font-size: clamp(34px, 4vw, 46px);
		letter-spacing: -0.015em;
		font-weight: 450;
		margin: 0;
		font-variation-settings: "opsz" 48;
	}
	.work-meta {
		font-family: "JetBrains Mono", monospace;
		font-size: 12.5px;
		color: var(--fg3);
	}

	.featured-rows {
		display: flex;
		flex-direction: column;
		gap: 54px;
		margin-bottom: 64px;
	}

	.grid-heading {
		display: flex;
		align-items: baseline;
		gap: 14px;
		margin-bottom: 22px;
	}
	.grid-heading h3 {
		font-family: "Newsreader", serif;
		font-size: 24px;
		font-weight: 500;
		letter-spacing: -0.01em;
		margin: 0;
	}
	.rule {
		flex: 1;
		height: 1px;
		background: var(--line);
	}

	.filters {
		display: flex;
		flex-wrap: wrap;
		gap: 9px;
		margin-bottom: 34px;
	}
	.work-chip {
		font-family: "Hanken Grotesk", sans-serif;
		font-size: 13px;
		font-weight: 600;
		padding: 8px 16px;
		border-radius: 999px;
		cursor: pointer;
		border: 1px solid var(--line2);
		background: transparent;
		color: var(--fg2);
		transition: color 0.18s ease, border-color 0.18s ease;
	}
	.work-chip:hover {
		color: var(--ink);
	}
	.work-chip.chip-on {
		background: var(--primary);
		color: var(--primary-ink);
		border-color: var(--primary);
	}

	.work-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 24px;
	}

	.foundations {
		margin-top: 54px;
	}
	.foundations .grid-heading {
		margin-bottom: 6px;
	}
	.foundations-lede {
		font-size: 13.5px;
		color: var(--fg3);
		margin: 0 0 20px;
		max-width: 60ch;
	}
	.foundations-list {
		display: flex;
		flex-direction: column;
	}
	.foundation-item {
		display: grid;
		grid-template-columns: 1fr auto;
		gap: 20px;
		align-items: center;
		padding: 16px 4px;
		border-top: 1px solid var(--line);
	}
	.foundation-meta {
		display: flex;
		align-items: baseline;
		gap: 14px;
		flex-wrap: wrap;
	}
	.foundation-title {
		font-family: "Newsreader", serif;
		font-size: 19px;
		font-weight: 500;
		color: var(--ink);
	}
	.foundation-tag {
		font-family: "JetBrains Mono", monospace;
		font-size: 11px;
		color: var(--fg3);
	}
	.foundation-links {
		display: flex;
		gap: 16px;
	}
	.lnk-muted {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		font-size: 12.5px;
		font-weight: 600;
		color: var(--fg2);
		text-decoration: none;
	}
	.lnk-muted:hover {
		color: var(--ink);
	}
	.lnk-accent {
		display: inline-flex;
		align-items: center;
		gap: 5px;
		font-size: 12.5px;
		font-weight: 600;
		color: var(--accent);
		text-decoration: none;
	}
	.lnk-accent:hover {
		color: var(--accent-bright);
	}
</style>

<script>
	const section = document.getElementById("work");
	if (section) {
		const chips = Array.from(
			section.querySelectorAll<HTMLButtonElement>(".work-chip"),
		);
		const cards = Array.from(
			section.querySelectorAll<HTMLElement>("[data-card]"),
		);
		const featuredRows = document.getElementById("featured-rows");
		const foundations = document.getElementById("foundations");
		const gridHeadingText = document.getElementById("grid-heading-text");
		const gridHeading = document.getElementById("grid-heading");

		function setFilter(filter: string) {
			const all = filter === "All";

			chips.forEach((c) =>
				c.classList.toggle("chip-on", c.dataset.filter === filter),
			);

			let visibleCount = 0;
			cards.forEach((card) => {
				const show = all
					? card.dataset.default === "true"
					: card.dataset.cat === filter;
				card.classList.toggle("is-hidden", !show);
				if (show) {
					// Filtering is interactive — never leave a shown card stuck pre-reveal.
					card.classList.add("r-shown");
					visibleCount++;
				}
			});

			featuredRows?.classList.toggle("is-hidden", !all);
			foundations?.classList.toggle("is-hidden", !all);
			gridHeading?.classList.toggle("is-hidden", visibleCount === 0);
			if (gridHeadingText) {
				gridHeadingText.textContent = all ? "More projects" : "Filtered projects";
			}
		}

		chips.forEach((chip) =>
			chip.addEventListener("click", () =>
				setFilter(chip.dataset.filter || "All"),
			),
		);
	}
</script>
