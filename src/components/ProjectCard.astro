---
import { Image } from "astro:assets";
import Icon from "./Icon.astro";
import type { Project } from "../data/projects";

interface Props {
	project: Project;
	/** True when this card is part of the default "All" grid (non-featured, non-foundation). */
	inDefault: boolean;
}

const { project, inDefault } = Astro.props;
---

<article
	class:list={["work-card", { "is-hidden": !inDefault }]}
	data-card
	data-cat={project.cat}
	data-default={inDefault ? "true" : "false"}
	data-reveal
>
	<div class="card-shot">
		{project.image && <Image src={project.image} alt={project.title} loading="lazy" />}
		{project.featured && <span class="card-badge">Featured</span>}
	</div>
	<div class="card-body">
		<div class="card-tag">{project.tag}</div>
		<h3 class="card-title">{project.title}</h3>
		<p class="card-blurb">{project.blurb}</p>
		<div class="chip-row">
			{project.tech.map((t) => <span class="tech-chip">{t}</span>)}
		</div>
		<div class="card-links">
			<a href={project.github} target="_blank" rel="noopener noreferrer" class="lnk-muted">
				<Icon name="github" size={15} aria-hidden="true" /> Code
			</a>
			<a href={project.live} target="_blank" rel="noopener noreferrer" class="lnk-accent">
				Live demo <span>→</span>
			</a>
		</div>
	</div>
</article>

<style>
	.work-card {
		background: var(--card);
		border: 1px solid var(--line);
		border-radius: 13px;
		overflow: hidden;
		display: flex;
		flex-direction: column;
		transition:
			transform 0.22s cubic-bezier(0.2, 0.6, 0.2, 1),
			box-shadow 0.22s,
			border-color 0.22s;
		box-shadow: var(--shadow);
	}
	.work-card:hover {
		transform: translateY(-5px);
		box-shadow: var(--shadow-lift);
		border-color: var(--line2);
	}
	.card-shot {
		position: relative;
		aspect-ratio: 16 / 10;
		overflow: hidden;
		background-color: var(--bg);
		border-bottom: 1px solid var(--line);
	}
	.card-shot :global(img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: top center;
	}
	.card-badge {
		position: absolute;
		top: 11px;
		left: 11px;
		padding: 4px 10px;
		border-radius: 999px;
		background: var(--primary);
		color: var(--primary-ink);
		font-size: 10.5px;
		font-weight: 700;
		letter-spacing: 0.07em;
		text-transform: uppercase;
	}
	.card-body {
		padding: 18px 19px 20px;
		display: flex;
		flex-direction: column;
		gap: 11px;
		flex: 1;
	}
	.card-tag {
		font-size: 11px;
		font-weight: 600;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--accent);
	}
	.card-title {
		font-family: "Newsreader", serif;
		font-size: 22px;
		font-weight: 500;
		letter-spacing: -0.01em;
		line-height: 1.15;
		margin: 0;
	}
	.card-blurb {
		font-size: 13.5px;
		line-height: 1.55;
		color: var(--fg2);
		margin: 0;
		flex: 1;
	}
	.chip-row {
		display: flex;
		flex-wrap: wrap;
		gap: 6px;
		margin-top: 2px;
	}
	.tech-chip {
		font-family: "JetBrains Mono", monospace;
		font-size: 10.5px;
		color: var(--chip-ink);
		background: var(--chip-bg);
		border: 1px solid var(--chip-line);
		border-radius: 999px;
		padding: 3px 9px;
	}
	.card-links {
		display: flex;
		gap: 18px;
		padding-top: 13px;
		margin-top: 3px;
		border-top: 1px solid var(--line);
	}
	.lnk-muted {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		font-size: 13px;
		font-weight: 600;
		color: var(--fg2);
		text-decoration: none;
	}
	.lnk-muted:hover {
		color: var(--ink);
	}
	.lnk-accent {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		font-size: 13px;
		font-weight: 600;
		color: var(--accent);
		text-decoration: none;
	}
	.lnk-accent:hover {
		color: var(--accent-bright);
	}
</style>
