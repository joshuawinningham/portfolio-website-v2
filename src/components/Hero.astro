---
import { Image } from "astro:assets";
import Icon from "./Icon.astro";
import inventoryShot from "../assets/inventory-order-tracker.png";
---

<section id="top" data-r="hero" class="hero">
	<div class="hero-copy">
		<div class="eyebrow">
			<span class="eyebrow-dot"></span>
			Full-Stack Developer &amp; SEO Specialist
		</div>
		<h1 class="hero-title">
			I turn ideas into <em>production-ready</em> web applications.
		</h1>
		<p class="hero-lede">
			I build elegant, scalable applications — front to back with React, Next.js
			and .NET — paired with an SEO specialist's instinct for performance and how
			things get found.
		</p>
		<div class="hero-ctas">
			<a href="#work" class="btn-fill">View the work</a>
			<a href="#contact" class="btn-ghost">Get in touch <span class="arrow">→</span></a>
		</div>
		<div data-r="hero-stats" class="hero-stats">
			<span class="stat"><Icon name="code-2" size={17} class="stat-icon" aria-hidden="true" /> Front to back</span>
			<span class="stat"><Icon name="search" size={17} class="stat-icon" aria-hidden="true" /> SEO-driven</span>
			<span class="stat"><Icon name="zap" size={17} class="stat-icon" aria-hidden="true" /> Performance-first</span>
		</div>
	</div>

	<div class="hero-shot-wrap">
		<div class="browser">
			<div class="browser-bar">
				<span class="dot dot-red"></span>
				<span class="dot dot-yellow"></span>
				<span class="dot dot-green"></span>
				<span class="browser-url">inventory-tracker.app</span>
			</div>
			<div class="browser-screen">
				<Image src={inventoryShot} alt="Inventory & Order Tracker" loading="eager" />
			</div>
		</div>
		<div class="shot-caption">
			<span class="caption-dot"></span>
			<div>
				<div class="caption-kicker">Recently shipped</div>
				<div class="caption-title">Inventory &amp; Order Tracker</div>
			</div>
		</div>
	</div>
</section>

<style>
	.hero {
		max-width: 1200px;
		margin: 0 auto;
		padding: 84px 32px 76px;
		display: grid;
		grid-template-columns: 1.04fr 0.96fr;
		gap: 60px;
		align-items: center;
	}
	.hero-copy {
		display: flex;
		flex-direction: column;
		gap: 24px;
	}
	.eyebrow {
		display: inline-flex;
		align-items: center;
		gap: 9px;
		font-size: 12px;
		font-weight: 600;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--fg3);
	}
	.eyebrow-dot {
		width: 7px;
		height: 7px;
		border-radius: 50%;
		background: var(--accent-bright);
	}
	.hero-title {
		font-family: "Newsreader", serif;
		font-size: clamp(48px, 5.6vw, 76px);
		line-height: 1.03;
		letter-spacing: -0.02em;
		font-weight: 420;
		margin: 0;
		font-variation-settings: "opsz" 72;
	}
	.hero-title em {
		font-style: italic;
		color: var(--accent);
	}
	.hero-lede {
		font-size: 19px;
		line-height: 1.58;
		color: var(--fg2);
		margin: 0;
		max-width: 48ch;
	}
	.hero-ctas {
		display: flex;
		gap: 13px;
		margin-top: 6px;
	}
	.btn-fill {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		font-size: 15px;
		font-weight: 600;
		text-decoration: none;
		padding: 14px 24px;
		background: var(--primary);
		color: var(--primary-ink);
		border-radius: 10px;
	}
	.btn-fill:hover {
		background: var(--primary-hover);
	}
	.btn-ghost {
		display: inline-flex;
		align-items: center;
		gap: 7px;
		font-size: 15px;
		font-weight: 600;
		text-decoration: none;
		padding: 14px 24px;
		background: transparent;
		color: var(--ink);
		border: 1px solid var(--line2);
		border-radius: 10px;
	}
	.btn-ghost:hover {
		border-color: var(--ink);
	}
	.btn-ghost .arrow {
		color: var(--accent);
	}
	.hero-stats {
		display: flex;
		gap: 26px;
		flex-wrap: wrap;
		margin-top: 14px;
	}
	.stat {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		font-size: 13.5px;
		color: var(--fg2);
	}
	.stat-icon {
		color: var(--primary);
	}

	.hero-shot-wrap {
		position: relative;
	}
	.browser {
		border-radius: 14px;
		overflow: hidden;
		background: var(--card);
		border: 1px solid var(--line);
		box-shadow: var(--shadow-lift);
	}
	.browser-bar {
		height: 38px;
		background: var(--chrome);
		border-bottom: 1px solid var(--line);
		display: flex;
		align-items: center;
		gap: 7px;
		padding: 0 14px;
	}
	.dot {
		width: 10px;
		height: 10px;
		border-radius: 50%;
	}
	.dot-red {
		background: #e8533c;
	}
	.dot-yellow {
		background: #d4a23a;
	}
	.dot-green {
		background: #3da858;
	}
	.browser-url {
		margin-left: 12px;
		flex: 1;
		max-width: 230px;
		height: 20px;
		border-radius: 6px;
		background: var(--bg);
		border: 1px solid var(--line);
		display: flex;
		align-items: center;
		padding: 0 10px;
		font-family: "JetBrains Mono", monospace;
		font-size: 10.5px;
		color: var(--fg3);
	}
	.browser-screen {
		aspect-ratio: 16 / 10;
		overflow: hidden;
		background: var(--bg);
	}
	.browser-screen :global(img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: top;
	}
	.shot-caption {
		position: absolute;
		bottom: -20px;
		left: 24px;
		background: var(--card);
		border: 1px solid var(--line);
		border-radius: 10px;
		padding: 11px 15px;
		box-shadow: var(--shadow);
		display: flex;
		align-items: center;
		gap: 10px;
	}
	.caption-dot {
		width: 8px;
		height: 8px;
		border-radius: 50%;
		background: var(--primary);
	}
	.caption-kicker {
		font-family: "JetBrains Mono", monospace;
		font-size: 10px;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		color: var(--fg3);
	}
	.caption-title {
		font-family: "Newsreader", serif;
		font-style: italic;
		font-size: 14.5px;
		color: var(--ink);
	}
</style>
